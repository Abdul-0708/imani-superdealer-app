# Copy this file to .env and fill in real values for production.

# HTTP port the server listens on
PORT=3000

# Secret used to sign login tokens. CHANGE THIS to a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret

# Which database to use: "file" for local development, "mysql" for production hosting.
DB_DRIVER=file

# File-store location (only used when DB_DRIVER=file)
DB_FILE=./data/dev-db.json

# MySQL connection (only used when DB_DRIVER=mysql)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=imani
MYSQL_PASSWORD=
MYSQL_DATABASE=imani_superdealer

# Seed accounts created on first run (change the passwords after first login)
SEED_OM_USER=om
SEED_OM_PASS=imani123
SEED_MD_USER=md
SEED_MD_PASS=imani123
